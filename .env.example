# Skopiuj do .env i uzupełnij wartości
# cp .env.example .env

# ── GCP ───────────────────────────────────────────────────────────────────────
GCP_PROJECT=twoj-projekt-gcp
GCP_REGION=europe-central2

# ── Model ─────────────────────────────────────────────────────────────────────
# Opcja 1: model w GCS (produkcja)
MODEL_GCS_URI=gs://twoj-projekt-gcp-models/map-annotation/best_model.pt

# Opcja 2: lokalny plik (dev/test) — odkomentuj i zakomentuj MODEL_GCS_URI
# MODEL_PATH=models/best_model.pt

# ── Serwer ────────────────────────────────────────────────────────────────────
PORT=8080
